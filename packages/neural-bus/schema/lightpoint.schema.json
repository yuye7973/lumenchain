{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumenChain LightPoint",
  "type": "object",
  "required": ["nodeId", "kind", "label", "scope", "decision", "confidence"],
  "properties": {
    "nodeId": { "type": "string" },
    "kind": {
      "type": "string",
      "enum": ["file", "folder", "project", "task", "workflow", "agent", "schedule", "service", "report", "memory", "dataset", "design_artifact", "github_item", "notion_item", "browser_trace", "computer_session", "build_artifact", "visualization", "backup_snapshot", "approval_packet", "capability_surface"]
    },
    "label": { "type": "string" },
    "path": { "type": "string" },
    "hash": { "type": "string" },
    "size": { "type": "integer", "minimum": 0 },
    "mtime": { "type": "string" },
    "owner": { "type": "string" },
    "scope": { "type": "string" },
    "risk": { "type": "string" },
    "gitStatus": { "type": "string" },
    "runtimeStatus": { "type": "string" },
    "decision": {
      "type": "string",
      "enum": ["KEEP", "REBUILD", "MERGE", "ARCHIVE_CANDIDATE", "DELETE_CANDIDATE", "APPROVAL_REQUIRED", "UNKNOWN"]
    },
    "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "nextAction": { "type": "string" }
  },
  "additionalProperties": false
}
