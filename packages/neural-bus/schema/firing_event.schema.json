{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "LumenChain FiringEvent",
  "type": "object",
  "required": ["specversion", "id", "type", "source", "subject", "time", "datacontenttype", "data", "traceId", "status"],
  "properties": {
    "specversion": { "type": "string" },
    "id": { "type": "string" },
    "type": { "type": "string" },
    "source": { "type": "string" },
    "subject": { "type": "string" },
    "time": { "type": "string" },
    "datacontenttype": { "type": "string" },
    "data": { "type": "object" },
    "traceId": { "type": "string" },
    "status": {
      "type": "string",
      "enum": ["proposed", "suppressed", "fired", "failed", "verified", "cooldown"]
    }
  },
  "additionalProperties": false
}
